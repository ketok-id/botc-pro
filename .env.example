# BOTC Pro — docker compose environment.
# Copy to `.env` in the same folder and edit. `.env` is git-ignored.

# --- Bare server -----------------------------------------------------------
# Host port the plain WebSocket server binds to. Clients connect with
# ws://<host>:<BOTC_PORT>. Default is 7878.
#BOTC_PORT=7878

# --- TLS profile (Caddy) ---------------------------------------------------
# Domain Caddy terminates TLS for. Must have an A record pointing at this host.
# Enable with:  docker compose --profile tls up -d
#BOTC_DOMAIN=botc.example.com

# --- Cloudflare Tunnel profile --------------------------------------------
# Leave blank to use a "quick tunnel" (random *.trycloudflare.com URL each
# start, printed in `docker compose logs cloudflared`).
#
# Set to a tunnel token from the Cloudflare Zero Trust dashboard to run a
# named tunnel with a permanent URL on your own domain. The public hostname
# -> `server:7878` routing is configured in the dashboard, not here.
# Enable with:  docker compose --profile tunnel up -d
#CLOUDFLARE_TUNNEL_TOKEN=
